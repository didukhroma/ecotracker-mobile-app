<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lime_1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="20dp"
        android:paddingEnd="12dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/backLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_arrow_only"
            android:textColor="@color/lime_10"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/lessonNumberText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/lime_8"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/lessonTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/lime_10"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/lessonImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:background="#CAE897"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/lessonContentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/lime_10"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/markCompletedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="@string/mark_completed"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/lime_9"
            app:cornerRadius="6dp" />
    </LinearLayout>
</ScrollView>
