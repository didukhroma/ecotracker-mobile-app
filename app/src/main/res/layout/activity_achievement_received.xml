<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lime_1"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/woo_hoo"
        android:textColor="@color/lime_10"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/new_achievement_unlocked"
        android:textColor="@color/lime_8"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/achievementImage"
        android:layout_width="220dp"
        android:layout_height="160dp"
        android:layout_marginTop="16dp"
        android:background="#CAE897"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/lime_10"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/descriptionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/lime_10"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/claimButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="@string/claim"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/lime_9"
        app:cornerRadius="6dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/myAchievementsButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:text="@string/my_achievements"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/lime_7"
        app:cornerRadius="6dp" />
</LinearLayout>
