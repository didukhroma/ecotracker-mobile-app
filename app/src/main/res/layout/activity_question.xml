<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lime_1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="24dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/prevLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/prev_with_arrow"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stepCounterText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/step_progress"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/skipLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skip_with_arrow"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/lime_10"
            android:textSize="40sp" />

        <TextView
            android:id="@+id/stepSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/lime_9"
            android:textSize="20sp" />

        <LinearLayout
            android:id="@+id/step1Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/tell_me_about_yourself"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/first_name"
                android:textAlignment="center"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/firstNameInputLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/firstNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/first_name"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/last_name"
                android:textAlignment="center"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/lastNameInputLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lastNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/last_name"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/country"
                android:textAlignment="center"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/countryInputLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/countryDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:completionThreshold="1"
                    android:hint="@string/country"
                    android:inputType="none"
                    android:maxLines="1"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step2Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/step2_drive_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/drivesCarLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/drivesCarDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/yes_no"
                    android:inputType="none"
                    android:maxLines="1"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/step2_frequency_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/drivingFrequencyLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/drivingFrequencyDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/select_driving_frequency"
                    android:inputType="none"
                    android:maxLines="1"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/step2_car_type_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/carTypeLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/carTypeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/select_car_type"
                    android:inputType="none"
                    android:maxLines="1"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step3Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/step3_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dietOptionAllCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/lime_1"
                app:strokeColor="@color/lime_6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diet_all"
                            android:textColor="@color/lime_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/diet_all_desc"
                            android:textColor="@color/lime_9"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/dietOptionAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dietOptionNoRedMeatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/lime_1"
                app:strokeColor="@color/lime_6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diet_no_red_meat"
                            android:textColor="@color/lime_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/diet_no_red_meat_desc"
                            android:textColor="@color/lime_9"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/dietOptionNoRedMeat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dietOptionPescatarianCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/lime_1"
                app:strokeColor="@color/lime_6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diet_pescatarian"
                            android:textColor="@color/lime_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/diet_pescatarian_desc"
                            android:textColor="@color/lime_9"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/dietOptionPescatarian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dietOptionVeggieCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/lime_1"
                app:strokeColor="@color/lime_6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/diet_veggie"
                            android:textColor="@color/lime_10"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/diet_veggie_desc"
                            android:textColor="@color/lime_9"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/dietOptionVeggie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/dietErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/error_select_diet"
                android:textColor="@color/chart_red"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step4Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/step4_building_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/buildingTypeLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:boxBackgroundColor="@color/lime_3"
                app:boxStrokeColor="@color/lime_7"
                app:errorTextColor="@color/chart_red"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/buildingTypeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/select_building_type"
                    android:inputType="none"
                    android:maxLines="1"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/lime_10"
                    android:textColorHint="@color/lime_8" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/step4_bedrooms_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@color/lime_1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bedroomsMinusButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="-"
                    android:textColor="@color/lime_10"
                    app:cornerRadius="18dp"
                    app:strokeColor="@color/lime_8"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/bedroomsValueText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/lime_10"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bedroomsPlusButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="+"
                    android:textColor="@color/lime_10"
                    app:cornerRadius="18dp"
                    app:strokeColor="@color/lime_8"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/step4_people_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/step4_people_hint"
                android:textColor="@color/lime_9"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@color/lime_1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/peopleMinusButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="-"
                    android:textColor="@color/lime_10"
                    app:cornerRadius="18dp"
                    app:strokeColor="@color/lime_8"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/peopleValueText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/lime_10"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/peoplePlusButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="+"
                    android:textColor="@color/lime_10"
                    app:cornerRadius="18dp"
                    app:strokeColor="@color/lime_8"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step5Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/step5_question"
                android:textColor="@color/lime_10"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/goalCutCarbon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/goal_cut_carbon"
                android:textColor="@color/lime_10" />

            <CheckBox
                android:id="@+id/goalSaveMoney"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_save_money"
                android:textColor="@color/lime_10" />

            <CheckBox
                android:id="@+id/goalTakeBigSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_take_big_steps"
                android:textColor="@color/lime_10" />

            <CheckBox
                android:id="@+id/goalProtectNature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_protect_nature"
                android:textColor="@color/lime_10" />

            <CheckBox
                android:id="@+id/goalSaveWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/goal_save_water"
                android:textColor="@color/lime_10" />

            <TextView
                android:id="@+id/goalsErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/error_select_goal"
                android:textColor="@color/chart_red"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/lime_9"
            app:cornerRadius="6dp" />

    </LinearLayout>
</ScrollView>