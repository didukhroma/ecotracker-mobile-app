<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/lime_10"
                android:startColor="@color/lime_8" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:left="14dp" android:top="18dp" android:right="14dp" android:bottom="70dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="#335B8C00"
                android:startColor="#80FCFFE6" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
